# Martinez Auto Repair — Environment Variables
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local to version control.

# Supabase (public — safe to expose in browser)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase (server only — NEVER expose in browser)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend (server only)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=noreply@martinezautorepair.com
RESEND_TO_EMAIL=carlos@martinezautorepair.com

# Plausible Analytics (public)
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=martinez-auto.com

# Site URL (public)
NEXT_PUBLIC_SITE_URL=https://martinez-auto.com

# Blog revalidation (server only — optional)
REVALIDATION_SECRET=your-secret-here
